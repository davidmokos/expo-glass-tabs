{
  "name": "expo-glass-tabs",
  "version": "0.1.1",
  "description": "Floating liquid-glass tab bar for Expo Router — minimize-on-scroll, sliding highlight, finger scrubbing with haptics, and progressive edge blur.",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "source": "src/index.ts",
  "sideEffects": false,
  "files": [
    "build",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf build",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "expo",
    "expo-router",
    "react-native",
    "tab-bar",
    "tabs",
    "liquid-glass",
    "ios26",
    "glass",
    "bottom-bar",
    "minimize",
    "reanimated"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidmokos/expo-glass-tabs.git"
  },
  "bugs": {
    "url": "https://github.com/davidmokos/expo-glass-tabs/issues"
  },
  "homepage": "https://github.com/davidmokos/expo-glass-tabs#readme",
  "author": "David Mokos",
  "license": "MIT",
  "peerDependencies": {
    "expo-blur": "*",
    "expo-glass-effect": "*",
    "expo-haptics": "*",
    "expo-router": "*",
    "expo-symbols": "*",
    "react": "*",
    "react-native": "*",
    "react-native-gesture-handler": "*",
    "react-native-reanimated": "*",
    "react-native-safe-area-context": "*",
    "react-native-screens": "*"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "expo": "~57.0.7",
    "expo-blur": "~57.0.2",
    "expo-glass-effect": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-router": "~57.0.7",
    "expo-symbols": "~57.0.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "react-dom": "$react"
  }
}
